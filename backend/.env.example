# Firebase Admin SDK Credentials
# Copy this file to .env and fill in your actual credentials
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-client-email@your-project.iam.gserviceaccount.com

# Firebase Web API Key (for Auth REST API - Login)
FIREBASE_API_KEY=your-firebase-web-api-key

# Upstash Redis / Vercel KV (for Rate Limiting)
# Get these from Vercel Dashboard → Storage → Upstash Redis
KV_REST_API_URL=your-upstash-redis-rest-url
KV_REST_API_TOKEN=your-upstash-redis-rest-token

# Server Config
PORT=3000
